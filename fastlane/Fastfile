# CardWise release automation.
# `beta` builds a signed App Store archive and uploads it to TestFlight.
# Triggered by CI on every push to `main` (see .github/workflows/ios-release.yml).
# App Store *submission for review* stays manual in App Store Connect.

require "base64"
require "fileutils"

default_platform(:ios)

APP_ID = "studio.tmj.cardwise"
WIDGET_ID = "studio.tmj.cardwise.widget"

platform :ios do
  desc "Build and upload a TestFlight build."
  lane :beta do
    setup_ci # creates an isolated temporary keychain when running on CI

    key_id = ENV.fetch("ASC_KEY_ID")
    issuer_id = ENV.fetch("ASC_ISSUER_ID")

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: ENV.fetch("ASC_KEY_P8_BASE64"),
      is_key_content_base64: true
    )

    # Import the distribution certificate (.p12) into the CI keychain so Xcode can sign.
    import_certificate(
      certificate_path: ENV.fetch("DIST_CERT_P12_PATH"),
      certificate_password: ENV.fetch("DIST_CERT_PASSWORD", ""),
      keychain_name: ENV.fetch("MATCH_KEYCHAIN_NAME", "fastlane_tmp_keychain"),
      keychain_password: ENV.fetch("MATCH_KEYCHAIN_PASSWORD", "")
    )

    # Download (creating if missing) App Store provisioning profiles for the app and its
    # widget extension via the ASC API key, so both the archive and the export sign
    # manually against known profiles.
    get_provisioning_profile(api_key: api_key, app_identifier: APP_ID, readonly: false)
    app_profile = lane_context[SharedValues::SIGH_NAME]

    get_provisioning_profile(api_key: api_key, app_identifier: WIDGET_ID, readonly: false)
    widget_profile = lane_context[SharedValues::SIGH_NAME]

    # Force *manual* signing on the freshly-generated project (xcodegen regenerates it each
    # CI run, so this never touches project.yml or local dev). Previously the archive used
    # automatic signing with -allowProvisioningUpdates, which made xcodebuild mint a new
    # Apple Development certificate every run until the account hit its certificate cap
    # ("Your account has reached the maximum number of certificates"). Pinning each target
    # to the imported Apple Distribution cert + the profile fetched above means xcodebuild
    # signs with what's already there and never tries to create a certificate.
    update_code_signing_settings(
      path: "CardWise.xcodeproj",
      use_automatic_signing: false,
      team_id: "K434CK85HW",
      targets: ["CardWise"],
      code_sign_identity: "Apple Distribution",
      profile_name: app_profile,
      bundle_identifier: APP_ID
    )
    update_code_signing_settings(
      path: "CardWise.xcodeproj",
      use_automatic_signing: false,
      team_id: "K434CK85HW",
      targets: ["CardWiseWidget"],
      code_sign_identity: "Apple Distribution",
      profile_name: widget_profile,
      bundle_identifier: WIDGET_ID
    )

    # Next build number = highest already on TestFlight + 1 (0 -> 1 for the very first build).
    next_build = (latest_testflight_build_number(api_key: api_key, app_identifier: APP_ID) rescue 0) + 1

    # Archive + export both sign manually with the profiles fetched above; no
    # -allowProvisioningUpdates, so xcodebuild never logs into the portal or mints certs.
    build_app(
      project: "CardWise.xcodeproj",
      scheme: "CardWise",
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{next_build}",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          APP_ID => app_profile,
          WIDGET_ID => widget_profile
        }
      }
    )

    # Upload by invoking altool directly instead of via upload_to_testflight. fastlane's
    # wrapper hands altool the API key in a way that makes Xcode 26's altool fail JWT
    # generation ("Failed to generate JWT token … 259"), even though the key itself is
    # valid (it authenticates against the ASC REST API fine). Writing the key to altool's
    # canonical AuthKey_<id>.p8 location and calling altool ourselves sidesteps that.
    keys_dir = File.expand_path("~/.appstoreconnect/private_keys")
    FileUtils.mkdir_p(keys_dir)
    key_file = File.join(keys_dir, "AuthKey_#{key_id}.p8")
    File.write(key_file, Base64.decode64(ENV.fetch("ASC_KEY_P8_BASE64")))
    begin
      ipa = lane_context[SharedValues::IPA_OUTPUT_PATH]
      sh("xcrun", "altool", "--upload-app", "-f", ipa, "-t", "ios",
         "--apiKey", key_id, "--apiIssuer", issuer_id, "--verbose")
    ensure
      File.delete(key_file) if File.exist?(key_file)
    end
  end
end
